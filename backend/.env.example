# Supabase
SUPABASE_PROJECT_REF=xxxxxxxxxxxxx
# SUPABASE_URL is derived automatically from SUPABASE_PROJECT_REF (https://<ref>.supabase.co)
# Only set this manually if you need to override the derived value
# SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI (default provider API key)
OPENAI_API_KEY=sk-proj-...

# OpenRouter (optional - for OpenRouter provider)
OPENROUTER_API_KEY=sk-or-v1-...

# LM Studio (optional - only needed if LM Studio requires auth)
LM_STUDIO_API_KEY=lm-studio

# Cohere (optional - for reranking)
COHERE_API_KEY=cohere
COHERE_RERANK_MODEL=rerank-english-v3.0

# Hybrid Search (Module 6)
HYBRID_SEARCH_ENABLED=true
HYBRID_VECTOR_WEIGHT=0.5
HYBRID_KEYWORD_WEIGHT=0.5

# Reranking (Module 6)
RERANKING_ENABLED=true
RERANKING_PROVIDER=local
RERANKING_TOP_N=5
RERANKING_RETRIEVAL_MULTIPLIER=3
LOCAL_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Provider defaults (optional - fallback values)
# These are used when no provider is specified in chat requests
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_BASE_URL=https://api.openai.com/v1

# LangSmith
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=default
LANGSMITH_TRACING=true

# Tavily (Module 7)
TAVILY_API_KEY=tvly-...
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5

# Text-to-SQL (Module 7)
TEXT_TO_SQL_ENABLED=true

# SQL Query Role (Module 7)
SQL_QUERY_ROLE_PASSWORD=secure_password_here

# Document Processing (unchanged)
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_FILE_SIZE_MB=10
SUPPORTED_FILE_TYPES="pdf,docx,pptx,html,md,txt,csv,json,xml,rtf"

# HuggingFace Hub (Windows - suppress symlink warnings, set to 1 on Windows)
HF_HUB_DISABLE_SYMLINKS_WARNING=0

# Server
PORT=8000
CORS_ORIGINS=http://localhost:5173

# Test Credentials (for automated tests)
TEST_EMAIL=test@...
TEST_PASSWORD=***

# Eval Integration Tests
# Set to true to enable eval integration tests (clean DB + ingest postmortem docs).
# WARNING: this deletes and re-ingests postmortem docs for the TEST_EMAIL user each run.
EVAL_DOCS_INGESTED=false
